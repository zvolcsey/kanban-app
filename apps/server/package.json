{
  "name": "@kanban-app/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm dlx prisma generate && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@kanban-app/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
