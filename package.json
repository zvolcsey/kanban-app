{
  "name": "kanban-app",
  "private": true,
  "version": "1.0.0",
  "description": "A Kanban portfolio web app.",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --filter './apps/*' --filter './packages/*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "pnpm --filter server run prisma:generate",
    "validate": "pnpm run prisma:generate && npm-run-all --parallel typecheck format:check lint build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f db",
    "db:shell": "docker compose exec db psql -U postgres -d kanban_app",
    "prepare": "husky"
  },
  "keywords": [
    "kanban",
    "web app"
  ],
  "author": "Zoltán Völcsey <zvolcsey@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
